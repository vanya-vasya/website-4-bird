generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String            @id @default(cuid())
  clerkId              String            @unique
  email                String            @unique
  photo                String
  firstName            String?
  lastName             String?
  usedGenerations      Int               @default(0)
  availableGenerations Int               @default(20)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  transactions         Transaction[]
  activityLogs         ActivityLog[]
  chefLogs             ChefLog[]
  nutritionistLogs     NutritionistLog[]
  trackerLogs          TrackerLog[]
}

// Your Own Chef — recipe generation logs
model ChefLog {
  id            String   @id @default(cuid())
  userId        String
  activityLogId String?  @unique
  tokensUsed    Int      @default(0)
  // metadata: { recipeName, cuisine, portionSize, mainIngredients, estimatedCalories, prompt, responsePreview }
  metadata      Json?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [clerkId])

  @@index([userId, createdAt])
}

// Your Own Nutritionist — nutrition analysis logs
model NutritionistLog {
  id            String   @id @default(cuid())
  userId        String
  activityLogId String?  @unique
  tokensUsed    Int      @default(0)
  // metadata: { analysisType, estimatedCalories, protein, carbs, fat, prompt, responsePreview }
  metadata      Json?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [clerkId])

  @@index([userId, createdAt])
}

// Your Own Tracker — calorie tracking logs
model TrackerLog {
  id            String   @id @default(cuid())
  userId        String
  activityLogId String?  @unique
  tokensUsed    Int      @default(0)
  // metadata: { mealType, totalCalories, hasImage, fileName, prompt, responsePreview }
  metadata      Json?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [clerkId])

  @@index([userId, createdAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  toolId      String
  toolName    String
  tokensUsed  Int      @default(0)
  metadata    Json?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [clerkId])

  @@index([userId, createdAt])
  @@index([userId, toolId])
}

model Transaction {
  id                  String    @id @default(cuid())
  tracking_id         String
  userId              String
  status              String?
  amount              Int?
  currency            String?
  description         String?
  type                String?
  payment_method_type String?
  message             String?
  paid_at             DateTime?
  receipt_url         String?
  createdAt           DateTime  @default(now())
  reason              String?
  webhookEventId      String?
  user                User      @relation(fields: [userId], references: [clerkId])

  @@index([userId, createdAt])
  @@index([webhookEventId])
}
